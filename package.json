{
  "name": "frasberg-ai-monorepo",
  "private": true,
  "version": "6.5.0",
  "description": "Frasberg AI Backend — Behavioral Governance and Codex Architecture",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "test": "jest",
    "test:codex": "jest tests/codex_architecture",
