{
  "Sofia Chat TypeScript": {
    "prefix": "sofiaChatTs",
    "body": [
      "import { createChatMessage, sendChat } from '@sofia/core';",
      "",
      "interface ChatOptions {",
      "  context?: string;",
      "  temperature?: number;",
      "  maxTokens?: number;",
      "}",
      "",
      "async function ${1:chatWithSofia}(${2:userMessage}: string, options: ChatOptions = {}): Promise<string> {",
      "  try {",
      "    const message = createChatMessage({",
      "      role: 'user',",
      "      content: ${2:userMessage},",
      "      context: options.context || '${3:default context}',",
      "    });",
      "",
      "    const response = await sendChat(message, {",
      "      temperature: options.temperature ?? 0.7,",
      "      maxTokens: options.maxTokens ?? 1000,",
      "    });",
      "",
      "    return response.content;",
      "  } catch (error) {",
      "    console.error('Sofia chat error:', error);",
      "    throw error;",
      "  }",
      "}",
      "",
      "// Usage:",
      "// const result = await ${1:chatWithSofia}('${4:Your question here}');"
    ],
    "description": "TypeScript chat function template for Sofia Core"
  },
