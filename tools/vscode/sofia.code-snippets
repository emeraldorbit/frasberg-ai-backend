  "Sofia Streaming": {
    "prefix": "sofiaStream",
    "body": [
      "import { createStreamChat } from '@sofia/core';",
      "",
      "async function ${1:streamChatResponse}(${2:userMessage}: string): Promise<void> {",
      "  try {",
      "    const stream = await createStreamChat({",
      "      message: ${2:userMessage},",
      "      context: '${3:default context}',",
      "      temperature: ${4:0.7},",
      "    });",
      "",
      "    // Handle streaming response",
      "    for await (const chunk of stream) {",
      "      if (chunk.type === 'content') {",
      "        process.stdout.write(chunk.data);",
      "      } else if (chunk.type === 'metadata') {",
      "        console.log(`\\nMetadata:`, chunk.data);",
      "      } else if (chunk.type === 'error') {",
      "        console.error(`Stream error:`, chunk.data);",
      "      }",
      "    }",
      "  } catch (error) {",
      "    console.error('Streaming chat error:', error);",
      "    throw error;",
      "  }",
      "}",
      "",
      "// Usage:",
      "// await ${1:streamChatResponse}('${5:Your streaming question here}');"
    ],
    "description": "Streaming chat response template for Sofia Core"
  },
