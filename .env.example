# Sofia Core API Configuration
SOFIA_CORE_API_KEY=your-key-here

# Provider Selection
AI_PROVIDER=sofia-core
IMAGE_PROVIDER=sofia-core
VIDEO_PROVIDER=sofia-core

# API Key Source (use 'github' or 'supabase')
AI_API_KEY_SOURCE=github
IMAGE_API_KEY_SOURCE=github
VIDEO_API_KEY_SOURCE=github

# Disabled External Providers
DISABLE_OPENAI=true
DISABLE_ANTHROPIC=true
DISABLE_GEMINI=true
DISABLE_STABILITY=true
DISABLE_EMERGENT=true

# Fallback Configuration
ALLOW_FALLBACK_PROVIDERS=false
