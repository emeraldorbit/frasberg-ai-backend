# Sofia Core API Configuration
SOFIA_CORE_API_KEY=your-key-here

# ── Canonical LLM Contract ──────────────────────────────────────────────────
# Provider to use for all LLM calls (local | openai | anthropic)
# Default is local (Ollama). Cloud providers require the corresponding flag.
LLM_PROVIDER=local
# Local (Ollama) endpoint
OLLAMA_ENDPOINT=http://localhost:11434/api/chat
# Default model (used when request model is "sofia-core" or omitted)
SOFIA_CORE_MODEL=llama3
# Sampling temperature (0.0 – 2.0)
SOFIA_CORE_TEMPERATURE=0.2
# Maximum output tokens per request
SOFIA_CORE_MAX_TOKENS=4096

# ── Governance: cloud providers are disabled by default ────────────────────
# Set ENABLE_OPENAI=true and LLM_PROVIDER=openai to use OpenAI
ENABLE_OPENAI=false
# Set ENABLE_ANTHROPIC=true and LLM_PROVIDER=anthropic to use Anthropic
ENABLE_ANTHROPIC=false

# ── Cloud provider API keys (only needed when the provider is enabled) ──────
# OPENAI_API_KEY=your-openai-key
# ANTHROPIC_API_KEY=your-anthropic-key
# LLM_API_KEY=fallback-key-for-cloud-providers

# ── Voice Gateway ──────────────────────────────────────────────────────────
# Base URL for the Sofia Core backend (used by voice-gateway to reach /api/llm/generate)
SOFIA_BACKEND_URL=http://localhost:8000

# ── Supabase (optional — usage logging) ───────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

